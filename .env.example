# NVIDIA NIM (LLM for chatbot)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_LLM_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b
NVIDIA_NIM_API_URL=https://integrate.api.nvidia.com/v1

# Google Gemini (embeddings for RAG)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL_NAME=gemini-embedding-2

# MongoDB (for local/Docker — direct pymongo connection)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=about_me

# MongoDB Atlas Data API (for Vercel/serverless — HTTPS, no TLS issues)
# 1. Go to Atlas → App Services → Create App → link to your cluster
# 2. Enable Data API, create API Key
# 3. Set URL and key here
MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
MONGODB_DATA_API_KEY=
MONGODB_DATA_SOURCE=Cluster0
